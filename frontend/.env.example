# Local WordPress: cp .env.local .env
# Staging (Vercel): cp .env.staging.wp.example .env
VITE_WP_API_URL=http://localhost:8080/wp-json
# Local dev without WordPress API (in-memory mock store)
VITE_USE_MOCK_DATA=false
VITE_SKILLS_URL=https://fitnesakademiya.ru

# Production (Beget): VITE_USE_MOCK_DATA=false, VITE_WP_API_URL=https://wp.trenerka-fit.ru/wp-json
# Configure WordPress SMTP (wp_mail) + option trenerka_frontend_url or TRENERKA_FRONTEND_URL in wp-config
# VITE_EMAIL_VERIFY_MOCK is implicit when VITE_USE_MOCK_DATA=true

# Clerk (optional — app builds without key; enable ClerkProvider when set)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# UploadThing (optional — avatar upload uses local preview until keys are set)
VITE_UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=sk_live_...
